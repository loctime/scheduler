/* ===============================
   HORARIOS – REGLAS ACTUALIZADAS
   =============================== */

/* ========= HELPERS LOCALES ========= */

// Verifica si el usuario autenticado puede actuar en nombre de un ownerId dado.
// Puede si: es el propio owner, o es un colaborador con ese ownerId, o tiene rol admin.
function horariosCanActFor(ownerId) {
  return isAuth()
    && ownerId != null
    && (
      uid() == ownerId
      || (
        exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
        && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId == ownerId
      )
    );
}

// Verifica si el usuario tiene rol admin dentro del sistema horarios
function horariosIsAdmin() {
  return isAuth()
    && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
    && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'admin';
}

// Verifica si el usuario tiene rol operador dentro del sistema horarios
function horariosIsOperador() {
  return isAuth()
    && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
    && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'operador';
}

// Verifica si el usuario tiene rol delivery dentro del sistema horarios
function horariosIsDelivery() {
  return isAuth()
    && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
    && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'delivery';
}

// Shortcut: admin o operador (puede editar stock, hacer pedidos, etc.)
function horariosIsAdminOrOperador() {
  return horariosIsAdmin() || horariosIsOperador();
}

// Cualquier rol con acceso de escritura sobre stock (admin, operador, factory, manager, maxdev)
function horariosIsStaff() {
  return isAuth()
    && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
    && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role
      in ['admin', 'operador', 'factory', 'manager', 'maxdev'];
}


/* ===============================
   PUBLIC COMPANIES
   =============================== */

match /apps/horarios/publicCompanies/{slug} {
  allow read: if true;

  allow create: if isAuth()
    && request.resource.data.ownerId == uid();

  allow update, delete: if false;
}

/* ===============================
   PUBLIC SCHEDULES
   =============================== */

match /apps/horarios/publicSchedules/{companySlug}/weeks/{weekId} {
  allow read: if true;

  allow create, update: if isAuth()
    && request.resource.data.ownerId == uid();

  allow delete: if false;
}

/* ===============================
   PUBLIC OWNERS
   =============================== */

match /apps/horarios/publicOwners/{ownerId} {
  allow read: if true;
  allow write: if horariosCanActFor(ownerId);
}

/* ===============================
   USERS
   =============================== */

match /apps/horarios/users/{userId} {
  // Un usuario puede leer su propio doc.
  // Un admin puede leer todos los usuarios de su mismo ownerId.
  allow read: if isAuth()
    && (
      userId == uid()
      || horariosCanActFor(
          get(/databases/$(db)/documents/apps/horarios/users/$(userId)).data.ownerId
        )
    );

  // Permitir listar usuarios del mismo ownerId
  allow list: if isAuth() && horariosCanActFor(
    get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId != null
      ? get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId
      : uid()
  );

  // Cualquier usuario autenticado puede crear su propio doc (registro inicial o por invitación)
  allow create: if isAuth() && userId == uid();

  // Un usuario puede actualizar su propio doc.
  // Un admin puede actualizar docs de su ownerId.
  allow update: if isAuth()
    && (
      userId == uid()
      || (
        resource.data.ownerId != null
        && horariosCanActFor(resource.data.ownerId)
      )
    );

  // Solo el propio usuario o el owner pueden borrar
  allow delete: if isAuth()
    && (
      userId == uid()
      || resource.data.ownerId == uid()
      || (
        resource.data.ownerId != null
        && horariosCanActFor(resource.data.ownerId)
      )
    );
}


/* ===============================
   INVITACIONES
   =============================== */

match /apps/horarios/invitaciones/{docId} {
  // Lectura pública para validar tokens en el flujo de registro
  allow read: if true;

  // Cualquier autenticado puede crear (el admin crea links para sus colaboradores)
  allow create: if isAuth();

  // Solo el creador puede actualizar, O el usuario que usa el link (marca como usado)
  allow update: if isAuth()
    && (
      resource.data.createdBy == uid()
      || (
        request.resource.data.usedBy == uid()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["usedBy", "usedAt"])
      )
    );

  allow delete: if isAuth()
    && resource.data.createdBy != null
    && horariosCanActFor(resource.data.createdBy);
}

/* ===============================
   EMPLOYEES
   =============================== */

match /apps/horarios/employees/{docId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
}

/* ===============================
   SHIFTS
   =============================== */

match /apps/horarios/shifts/{docId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);
  allow update: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
  allow delete: if horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   SCHEDULES
   =============================== */

match /apps/horarios/schedules/{docId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if isAuth();
}

/* ===============================
   WEEKS (base + versiones)
   =============================== */

match /apps/horarios/weeks/{baseWeekId} {
  allow read, write: if isAuth()
    && horariosCanActFor(
      resource != null ? resource.data.ownerId : request.resource.data.ownerId
    );

  match /versions/{versionNumber} {
    allow read, write: if isAuth()
      && horariosCanActFor(
        get(/databases/$(db)/documents/apps/horarios/weeks/$(baseWeekId)).data.ownerId
      );
  }
}

/* ===============================
   HISTORIAL (cambios de horarios)
   =============================== */

match /apps/horarios/historial/{historialId} {
  allow read: if isAuth() && resource.data.createdBy == uid();

  allow create: if isAuth() && request.resource.data.createdBy == uid();

  allow update: if false;

  allow delete: if isAuth() && resource.data.createdBy == uid();
}

/* ===============================
   EMPLOYEE FIXED RULES
   =============================== */

match /apps/horarios/employee_fixed_rules/{ruleId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
}

/* ===============================
   CONFIG
   =============================== */

match /apps/horarios/config/{docId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
}

/* ===============================
   SETTINGS
   =============================== */

match /apps/horarios/settings/{ownerId} {
  allow read: if isAuth()
    && (
      ownerId == uid()
      || horariosCanActFor(ownerId)
    );

  allow create: if isAuth()
    && (
      ownerId == uid()
      || horariosCanActFor(ownerId)
    );

  allow update: if isAuth()
    && (
      ownerId == uid()
      || horariosCanActFor(ownerId)
    )
    && unchanged("ownerId");

  allow delete: if false;
}

/* ===============================
   GROUPS + CONVERSACIONES + MENSAJES
   (sistema de mensajería interna)
   =============================== */

match /apps/horarios/groups/{groupId} {
  allow read: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosCanActFor(resource.data.ownerId)
    );

  allow create: if isAuth()
    && (
      request.resource.data.ownerId == uid()
      || horariosCanActFor(request.resource.data.ownerId)
    );

  allow update, delete: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosCanActFor(resource.data.ownerId)
    );
}

match /apps/horarios/conversaciones/{convId} {
  allow read: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosCanActFor(resource.data.ownerId)
    );

  allow create: if isAuth()
    && (
      request.resource.data.ownerId == uid()
      || horariosCanActFor(request.resource.data.ownerId)
    );

  allow update: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosCanActFor(resource.data.ownerId)
    );

  allow delete: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosIsAdmin()
      && horariosCanActFor(resource.data.ownerId)
    );
}

match /apps/horarios/mensajes/{msgId} {
  allow read: if isAuth()
    && (
      resource.data.ownerId == uid()
      || horariosCanActFor(resource.data.ownerId)
    );

  allow create: if isAuth()
    && (
      request.resource.data.ownerId == uid()
      || horariosCanActFor(request.resource.data.ownerId)
    );

  allow update, delete: if false;
}

/* ===============================
   TASKS
   =============================== */

match /apps/horarios/tasks/{taskId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
}

/* ===============================
   DAILY ACTIONS / STATUS
   =============================== */

match /apps/horarios/dailyActions/{ownerId} {
  allow read: if true;
  allow create, update, delete: if horariosCanActFor(ownerId);
}

match /apps/horarios/dailyActionStatus/{docId} {
  allow read: if true;
  allow create, update: if true;
  allow delete: if false;
}

match /apps/horarios/dailyTaskStatus/{docId} {
  allow read: if true;
  allow create, update: if true;
  allow delete: if false;
}

/* ===============================
   ENLACES PUBLICOS (pedidos WhatsApp)
   =============================== */

match /apps/horarios/enlaces_publicos/{docId} {
  allow read: if true;

  allow create, update: if isAuth()
    && horariosCanActFor(request.resource.data.ownerId);

  allow delete: if isAuth()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   PEDIDOS (grupos de productos)
   =============================== */

match /apps/horarios/pedidos/{docId} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);
  allow update: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
  allow delete: if horariosCanActFor(resource.data.ownerId);
}

match /apps/horarios/pedidos/{docId}/{sub=**} {
  allow read: if true;

  allow create: if horariosCanActFor(request.resource.data.ownerId);
  allow update: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  );
  allow delete: if horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   PRODUCTS (legacy — compatibilidad)
   Solo lectura pública. Escritura solo para admin.
   =============================== */

match /apps/horarios/products/{docId} {
  allow read: if true;

  allow create: if horariosIsAdmin()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update: if horariosIsAdmin()
    && horariosCanActFor(
      resource.data.ownerId != null
        ? resource.data.ownerId
        : request.resource.data.ownerId
    );

  allow delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   CATÁLOGO (productos del sistema nuevo)
   Solo admin puede crear/editar el catálogo.
   Todos los autenticados del mismo owner pueden leer.
   =============================== */

match /apps/horarios/catalogo/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdmin()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update: if horariosIsAdmin()
    && horariosCanActFor(
      resource.data.ownerId != null
        ? resource.data.ownerId
        : request.resource.data.ownerId
    );

  allow delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   STOCK UBICACIONES (stock por sucursal)
   Cualquier usuario autenticado puede leer y escribir.
   El frontend controla los permisos por rol.
   =============================== */

match /apps/horarios/stock_ubicaciones/{docId} {
  allow read, write: if isAuth();
}

/* ===============================
   STOCK MOVIMIENTOS (log de movimientos)
   =============================== */

match /apps/horarios/stock_movimientos/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if false;
}

/* ===============================
   PEDIDOS FÁBRICA (pedidos internos entre sucursales)
   =============================== */

match /apps/horarios/pedidos_fabrica/{docId} {
  // Cualquier colaborador autenticado puede leer pedidos de su ownerId
  allow read: if horariosCanActFor(resource.data.ownerId);

  // Admin y operador pueden crear pedidos
  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  // Admin puede actualizar cualquier pedido (para cambiar estado a despachado/recibido)
  // Operador puede actualizar solo pedidos que creó (para cancelar borradores)
  allow update: if horariosCanActFor(
    resource.data.ownerId != null
      ? resource.data.ownerId
      : request.resource.data.ownerId
  ) && horariosIsAdminOrOperador();

  allow delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   REMITOS LOG (documentos de envío)
   =============================== */

match /apps/horarios/remitos_log/{docId} {
  // Owner, admin, operador, y delivery asignado pueden leer
  allow read: if horariosCanActFor(resource.data.ownerId)
    || (horariosIsDelivery() && resource.data.assignedDeliveryId == uid());

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  // Validación por rol para actualizaciones específicas
  allow update: if horariosCanActFor(resource.data.ownerId)
    && (
      // Admin puede actualizar cualquier campo
      (horariosIsAdmin() && true)
      // Operador solo puede confirmar entrega
      || (horariosIsOperador() 
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["estado", "entregadoAt"])
          && request.resource.data.estado == "entregado")
      // Delivery solo puede marcar "en_camino"
      || (horariosIsDelivery() 
          && resource.data.assignedDeliveryId == uid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["estado", "enCaminoAt"])
          && request.resource.data.estado == "en_camino")
    );

  allow delete: if false;
}

/* ===============================
   RECEPCIONES LOG (confirmaciones de entrega)
   =============================== */

match /apps/horarios/recepciones_log/{docId} {
  // Todos los colaboradores del ownerId pueden leer recepciones
allow read: if isAuth() && (
  resource == null
  || horariosCanActFor(resource.data.ownerId)
);
  // Admin y operador pueden confirmar recepciones
  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  // Una recepción es inmutable una vez creada
  allow update, delete: if false;
}

/* ===============================
   COUNTERS (numeración secuencial)
   =============================== */

match /apps/horarios/counters/{docId} {
  allow read: if isAuth();

  // Los counters se actualizan dentro de transacciones — cualquier autenticado puede
  allow write: if isAuth();
}

/* ===============================
   AUDIT LOGS
   =============================== */

match /apps/horarios/audit_logs/{docId} {
  allow read: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);

  allow create: if isAuth();

  allow update, delete: if false;
}

/* ===============================
   LOTS (vencimientos — VencApp)
   =============================== */

match /apps/horarios/lots/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update: if horariosIsAdminOrOperador()
    && horariosCanActFor(resource.data.ownerId);

  allow delete: if horariosIsAdminOrOperador()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   WAREHOUSE ZONES (zonas del depósito — VencApp)
   =============================== */

match /apps/horarios/warehouse_zones/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update: if horariosIsAdminOrOperador()
    && horariosCanActFor(resource.data.ownerId);

  allow delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   GROUPS + CONVERSACIONES + MENSAJES
   (sistema de mensajería interna)
   =============================== */

match /apps/horarios/groups/{groupId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdmin()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

match /apps/horarios/conversaciones/{convId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update: if horariosCanActFor(resource.data.ownerId);

  allow delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

match /apps/horarios/mensajes/{msgId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if false;
}

/* ===============================
   REMITOS LEGACY (solo lectura — datos históricos)
   No se escribe más acá, solo se lee pedido-publico
   =============================== */

match /apps/horarios/remitos/{docId} {
  allow read: if true;
  allow create: if isAuth();
  allow update, delete: if false;
}
/* ===============================
   GRUPOS CATÁLOGO
   =============================== */

match /apps/horarios/grupos_catalogo/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);

  allow create: if horariosIsAdmin()
    && horariosCanActFor(request.resource.data.ownerId);

  allow update, delete: if horariosIsAdmin()
    && horariosCanActFor(resource.data.ownerId);
}

/* ===============================
   STOCK ACTUAL (legacy)
   =============================== */

match /apps/horarios/stock_actual/{docId} {
  allow read: if horariosCanActFor(resource.data.ownerId);
  allow create: if horariosIsAdminOrOperador()
    && horariosCanActFor(request.resource.data.ownerId);
  allow update, delete: if horariosIsAdminOrOperador()
    && horariosCanActFor(resource.data.ownerId);
}
match /apps/horarios/recepciones/{docId} {
  allow read: if isAuth();
  allow create: if isAuth();
  allow update, delete: if false;
}

